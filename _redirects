# Mohsin Haematology Academy — URL routing for Cloudflare Pages.
# Evaluated top-to-bottom; first matching rule wins.
# Format: <from>   <to>   <status>
#   200 = internal rewrite (URL stays the same, content served from the target path)
#   301 = permanent redirect (browser URL changes)

# --- Folder-style guideline URLs — serve index.html in place (URL preserved) ---
/guidelines/anaemia-in-pregnancy/   /guidelines/anaemia-in-pregnancy/index.html   200
/guidelines/cll/                    /guidelines/cll/index.html                    200
/guidelines/itp/                    /guidelines/itp/index.html                    200
/guidelines/vte-cancer/             /guidelines/vte-cancer/index.html             200

# --- No-trailing-slash → clean trailing-slash form (browser URL updated) ---
/guidelines/anaemia-in-pregnancy    /guidelines/anaemia-in-pregnancy/             301
/guidelines/cll                     /guidelines/cll/                              301
/guidelines/itp                     /guidelines/itp/                              301
/guidelines/vte-cancer              /guidelines/vte-cancer/                       301

