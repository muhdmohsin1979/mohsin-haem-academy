#!/usr/bin/env bash
#
# pre-commit — runs the publishing guardrails on staged files before every
# commit, so errors are caught locally instead of in CI.
#
# Installed by scripts/install-hooks.sh (sets core.hooksPath).
# Bypass (emergency only): git commit --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# 1. Generate a unified diff of staged changes, zero-context so only actually
#    added lines get scanned (not unchanged surrounding lines from a rename).
STAGED_DIFF=$(mktemp)
STAGED_LIST=$(mktemp)
trap 'rm -f "$STAGED_DIFF" "$STAGED_LIST"' EXIT

# Exclude docs/templates/* from guardrail scanning — those files contain
# placeholder markers that would false-positive the checks. They are not
# published pages; real output always lives under /guidelines/<topic>/.
git diff --cached --unified=0 -M \
  -- . ':(exclude)docs/templates/**' > "$STAGED_DIFF"
git diff --cached --name-only --diff-filter=AM \
  | grep -Ei '\.(md|html)$' \
  | grep -vE '^docs/templates/' > "$STAGED_LIST" || true

# If no staged .md / .html content at all, skip silently.
if [ ! -s "$STAGED_LIST" ] && [ ! -s "$STAGED_DIFF" ]; then
  exit 0
fi

echo "pre-commit: scanning staged changes..."

# 2. Tone guard — diff mode (only added lines checked).
if ! python3 scripts/tone_guard.py --diff-from "$STAGED_DIFF"; then
  echo ""
  echo "pre-commit: tone_guard FAILED. Fix the flagged NEW lines and re-stage."
  echo "To bypass (emergency only): git commit --no-verify"
  exit 1
fi

# 3. Preflight — PII + internal link check on the staged files.
#    External link check is CI-only (--skip-links keeps the commit fast).
if [ -s "$STAGED_LIST" ]; then
  if ! python3 scripts/preflight.py --files-from "$STAGED_LIST" --skip-links; then
    echo ""
    echo "pre-commit: preflight FAILED. Fix the PII / internal-link issue(s) and re-stage."
    echo "To bypass (emergency only): git commit --no-verify"
    exit 1
  fi
fi

echo "pre-commit: PASS."
exit 0
